{
  "name": "sqlite-intelliview-vscode",
  "displayName": "SQLite IntelliView",
  "description": "Modern SQLite/SQLCipher database viewer and editor for VS Code: Monaco-powered queries, ER diagrams, cell editing, encryption, and more.",
  "version": "0.4.10",
  "publisher": "bowlerr",
  "author": {
    "name": "Bowlerr",
    "email": "cawbsprogramming@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bowlerr/sqlite-intelliview-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/Bowlerr/sqlite-intelliview-vscode/issues"
  },
  "homepage": "https://github.com/Bowlerr/sqlite-intelliview-vscode#readme",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "sqlite",
    "sqlcipher",
    "database",
    "viewer",
    "sql",
    "sqlcipher",
    "table",
    "editor",
    "vscode",
    "vscode-extension",
    "monaco-editor",
    "db-viewer",
    "db-editor",
    "pagination",
    "encryption",
    "developer-tools",
    "productivity",
    "code-insight",
    "data-visualization",
    "cell-editing"
  ],
  "engines": {
    "vscode": "^1.101.0",
    "node": ">=16.0.0"
  },
  "categories": [
    "Other",
    "Data Science",
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:sql",
    "onFileSystem:db",
    "onFileSystem:sqlite",
    "onFileSystem:sqlite3"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sqlite-intelliview-vscode.openDatabase",
        "title": "Open SQLite Database",
        "category": "SQLite IntelliView"
      },
      {
        "command": "sqlite-intelliview-vscode.connectWithKey",
        "title": "Connect with SQLCipher Key",
        "category": "SQLite IntelliView"
      },
      {
        "command": "sqlite-intelliview-vscode.refreshDatabase",
        "title": "Refresh Database",
        "category": "SQLite IntelliView"
      },
      {
        "command": "sqlite-intelliview-vscode.exportData",
        "title": "Export Data",
        "category": "SQLite IntelliView"
      },
      {
        "command": "sqlite-intelliview-vscode.checkpointWal",
        "title": "Checkpoint WAL and Refresh",
        "category": "SQLite IntelliView"
      }
    ],
    "customEditors": [
      {
        "viewType": "sqlite-intelliview-vscode.databaseEditor",
        "displayName": "SQLite Database IntelliView",
        "selector": [
          {
            "filenamePattern": "*.[dD][bB]"
          },
          {
            "filenamePattern": "*.[dD][bB]3"
          },
          {
            "filenamePattern": "*.[sS]3[dD][bB]"
          },
          {
            "filenamePattern": "*.[sS][lL]3"
          },
          {
            "filenamePattern": "*.[sS][qQ][lL][iI][tT][eE]"
          },
          {
            "filenamePattern": "*.[sS][qQ][lL][iI][tT][eE]3"
          }
        ],
        "priority": "default"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "sqlite-intelliview-vscode.databaseExplorer",
          "name": "Database Explorer",
          "when": "sqlite-intelliview-vscode.hasOpenDatabase",
          "icon": "$(database)"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "sqlite-intelliview-vscode.openDatabase",
          "when": "resourceExtname =~ /\\.(db3?|sqlite3?|s3db|sl3)$/i",
          "group": "1_open"
        }
      ],
      "view/title": [
        {
          "command": "sqlite-intelliview-vscode.refreshDatabase",
          "when": "view == sqlite-intelliview-vscode.databaseExplorer",
          "group": "navigation",
          "icon": "$(refresh)"
        }
      ]
    },
    "keybindings": [
      {
        "command": "sqlite-intelliview-vscode.openDatabase",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "explorerViewletVisible"
      },
      {
        "command": "sqlite-intelliview-vscode.connectWithKey",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "sqlite-intelliview-vscode.refreshDatabase",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      },
      {
        "command": "sqlite-intelliview-vscode.exportData",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      }
    ],
    "configuration": {
      "title": "SQLite IntelliView",
      "properties": {
        "sqliteIntelliView.additionalFileExtensions": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "uniqueItems": true,
          "markdownDescription": "Additional filename extensions to recognize as SQLite databases. Values may include a leading dot and are matched case-insensitively, for example `.database` or `sqlite-backup`. Invalid and duplicate values are ignored."
        },
        "sqliteIntelliView.defaultPageSize": {
          "type": "number",
          "default": 1000,
          "minimum": 10,
          "maximum": 100000,
          "description": "Default number of rows per page in data tables."
        },
        "sqliteIntelliView.walAutoCheckpoint": {
          "type": "boolean",
          "default": true,
          "description": "Automatically checkpoint WAL (Write-Ahead Logging) files before opening databases to ensure up-to-date data. Retained for backward compatibility; use walCheckpointMode for finer control."
        },
        "sqliteIntelliView.walCheckpointMode": {
          "type": "string",
          "enum": [
            "full",
            "passive",
            "off"
          ],
          "default": "full",
          "markdownDescription": "WAL checkpoint mode used when opening databases with `-wal` files. `full` merges WAL contents and may block writers, `passive` is less intrusive, and `off` skips auto-checkpointing. If `walAutoCheckpoint` is `false`, this setting is ignored and auto-checkpointing remains off."
        },
        "sqliteIntelliView.walMonitoring": {
          "type": "boolean",
          "default": true,
          "description": "Monitor WAL files for changes and automatically refresh the database view when changes are detected."
        },
        "sqliteIntelliView.externalRefreshDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 10000,
          "description": "Debounce window for external database refresh events (DB/WAL/SHM watcher bursts). Higher values reduce refresh noise; lower values refresh sooner."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "vendor": "node vendor-libs.js",
    "prepackage": "npm run vendor && npm run compile",
    "package": "vsce package",
    "release": "vsce publish",
    "release:openvsx": "npx ovsx publish",
    "release:all": "npm run release && npm run release:openvsx",
    "lint": "eslint src --fix",
    "check-types": "tsc --noEmit",
    "pretest": "npm run compile && npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.33",
    "@types/sortablejs": "^1.15.0",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.101.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "d3": "^7.8.5",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "monaco-editor": "^0.52.2",
    "sortablejs": "^1.15.6",
    "sql.js": "^1.13.0",
    "sqlite3": "^5.1.7"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
